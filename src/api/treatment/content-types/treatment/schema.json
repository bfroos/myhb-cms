{
  "kind": "collectionType",
  "collectionName": "treatments",
  "info": {
    "singularName": "treatment",
    "pluralName": "treatments",
    "displayName": "Treatment"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "internalLabel": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "type": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "default": "minimally-invasive",
      "enum": [
        "minimally-invasive",
        "abulatory",
        "operational"
      ]
    },
    "priceInEuroCent": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "customField": "plugin::amount-cents.price",
      "description": "DEPRECATED: durch Relation 'prices' ersetzt"
    },
    "isStartingPrice": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true,
      "default": true,
      "description": "DEPRECATED: durch Relation 'prices' ersetzt"
    },
    "prices": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::price.price",
      "mappedBy": "treatmentCategory"
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "treatments"
    },
    "reviews": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::review.review",
      "inversedBy": "relatedTreatments"
    },
    "treatmentPage": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::treatment-page.treatment-page",
      "inversedBy": "treatment"
    }
  }
}
