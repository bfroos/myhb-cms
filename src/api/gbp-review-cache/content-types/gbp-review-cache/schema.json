{
  "kind": "collectionType",
  "collectionName": "gbp_review_caches",
  "info": {
    "singularName": "gbp-review-cache",
    "pluralName": "gbp-review-caches",
    "displayName": "GBP Review Cache"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "cacheKey": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "payload": {
      "type": "json",
      "required": true
    },
    "expiresAt": {
      "type": "datetime",
      "required": true
    }
  }
}
