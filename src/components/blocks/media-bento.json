{
  "collectionName": "components_blocks_media_bentos",
  "info": {
    "displayName": "Media Bento",
    "icon": "dashboard"
  },
  "options": {},
  "attributes": {
    "headline": {
      "type": "string",
      "required": false
    },
    "intro": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    },
    "mediaItems": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "layout": {
      "type": "enumeration",
      "required": true,
      "default": "media-left",
      "enum": [
        "media-left",
        "media-right"
      ]
    },
    "links": {
      "type": "component",
      "component": "shared.button",
      "repeatable": true
    },
    "videoSettings": {
      "type": "component",
      "component": "shared.video-settings",
      "repeatable": false
    },
    "cardSettings": {
      "type": "component",
      "component": "shared.card-design",
      "repeatable": false
    }
  },
  "config": {}
}
